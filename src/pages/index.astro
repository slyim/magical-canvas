---
import MagicalCanvas from "../components/MagicalCanvas.astro";
import "../styles/style.css";
---

<html lang="en">
  <head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>MagicalCanvas</title>
  </head>
  <body>
    <div class="app-layout">
      <!-- TOP DOCK -->
      <div class="dock dock-top">
        <div class="control-group">
          <label for="color-picker">Color</label>
          <input type="color" id="color-picker" value="#b496ff" />
        </div>
        <div class="divider"></div>
        <div class="control-group">
          <label for="size-picker">Size</label>
          <input type="range" id="size-picker" min="5" max="100" value="25" />
        </div>
        <div class="divider"></div>
        <div class="control-group">
          <label for="opacity-picker">Opacity</label>
          <input type="range" id="opacity-picker" min="5" max="100" value="100" />
        </div>
      </div>

      <!-- LEFT DOCK -->
      <div class="dock dock-left">
        <label>Tools</label>
        <button id="brush-toggle" class="tool-btn active">Brush</button>
        <button id="eraser-toggle" class="tool-btn">Eraser</button>
        <div class="divider-h"></div>
        <label>Shapes</label>
        <button id="square-toggle" class="tool-btn">Square</button>
        <button id="ellipse-toggle" class="tool-btn">Ellipse</button>
        <button id="triangle-toggle" class="tool-btn">Triangle</button>
      </div>

      <!-- CENTER WORKSPACE -->
      <div class="workspace">
        <MagicalCanvas />
      </div>

      <!-- RIGHT DOCK -->
      <div class="dock dock-right">
        <label>Effects</label>
        <button id="rainbow-toggle" class="toggle-btn">Rainbow</button>
        <button id="anim-toggle" class="toggle-btn active">Animate</button>
        <button id="fade-toggle" class="toggle-btn">Fade</button>
        <div class="divider-h"></div>
        <div class="control-group vert">
          <label for="fade-speed">Speed</label>
          <input type="range" id="fade-speed" min="1" max="60" value="5" />
        </div>
      </div>

      <!-- BOTTOM DOCK -->
      <div class="dock dock-bottom">
        <button id="undo-btn">Undo</button>
        <button id="redo-btn">Redo</button>
        <div class="divider-h"></div>
        <button id="clear-btn">Clear Canvas</button>
        <button id="import-btn">Import PNG</button>
        <button id="export-btn">Export PNG</button>
      </div>
    </div>

    <script>
      import { initToolbar } from "../lib/toolbar.js";
      initToolbar();
    </script>
  </body>
</html>
