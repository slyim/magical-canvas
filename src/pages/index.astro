---
import MagicalCanvas from "../components/MagicalCanvas.astro";
import "../styles/style.css";
---

<html lang="en">
  <head>
    <title>MagicalCanvas</title>
    <style>
      body {
        margin: 0;
        height: 100vh;
        width: 100vw;
        display: flex;
        justify-content: center;
        align-items: center;
        overflow: hidden; /* Avoid scrollbars */
        background: #0d0617; /* match app background */
      }
      .app-layout {
        display: grid;
        grid-template-areas: 
          ". top ."
          "left center right"
          ". bottom .";
        grid-template-columns: 1fr auto 1fr;
        grid-template-rows: 1fr auto 1fr;
        box-sizing: border-box;
        padding: 20px;
        gap: 20px;
        width: 100vw;
        height: 100vh;
      }
      .dock {
        background: rgba(15, 15, 30, 0.9);
        border: 1px solid rgba(180, 150, 255, 0.3);
        border-radius: 16px;
        padding: 15px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        gap: 15px;
      }
      .dock-top { grid-area: top; justify-content: center; justify-self: stretch; align-self: end; }
      .dock-bottom { grid-area: bottom; justify-content: center; justify-self: stretch; align-self: start; }
      .dock-left { grid-area: left; flex-direction: column; justify-content: center; justify-self: end; align-self: stretch; }
      .dock-right { grid-area: right; flex-direction: column; justify-content: center; justify-self: start; align-self: stretch; }
      
      .workspace {
        grid-area: center;
        display: flex;
        justify-content: center;
        align-items: center;
        overflow: hidden;
        min-width: 0;
        min-height: 0;
      }
      
      /* Mobile First Responsive Transition! */
      @media (max-width: 1000px) {
        .app-layout {
          grid-template-areas: 
            "top"
            "left"
            "center"
            "right"
            "bottom";
          grid-template-columns: 1fr;
          grid-template-rows: auto auto 1fr auto auto;
          width: 100vw;
          height: 100dvh;
          overflow-y: auto; /* Allow layout to natively scroll */
          padding: 10px;
          gap: 12px;
          justify-content: stretch;
          align-content: start;
        }
        .dock-left, .dock-right, .dock-top, .dock-bottom {
          align-self: center; /* Remove strict constraints on mobile */
          justify-self: stretch; /* Match canvas width */
        }
        .dock-left, .dock-right {
          flex-direction: row;
          flex-wrap: wrap;
        }
        .dock {
          flex-wrap: wrap;
        }
        .divider-h { display: none; }
        .control-group.vert { flex-direction: row; }
      }
      
      /* Control Styling */
      .control-group {
        display: flex;
        align-items: center;
        gap: 8px;
        color: white;
      }
      .control-group.vert {
        flex-direction: column;
      }
      label {
        font-size: 0.85rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.9);
        letter-spacing: 0.5px;
        text-transform: uppercase;
      }
      input[type="color"] {
        -webkit-appearance: none;
        appearance: none;
        border: none;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        cursor: pointer;
        padding: 0;
        background: transparent;
        overflow: hidden;
        outline: none;
      }
      input[type="color"]::-webkit-color-swatch-wrapper { padding: 0; }
      input[type="color"]::-webkit-color-swatch {
        border: none;
        border-radius: 50%;
      }
      input[type="color"]::-moz-color-swatch {
        border: none;
        border-radius: 50%;
      }
      input[type="range"] {
        accent-color: #b496ff;
        cursor: pointer;
        width: 100px;
      }
      
      /* Buttons */
      button {
        background: rgba(180, 150, 255, 0.15);
        border: 1px solid rgba(180, 150, 255, 0.5);
        color: #fff;
        padding: 8px 16px;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
        font-size: 0.85rem;
        transition: all 0.2s ease;
      }
      button:hover {
        background: rgba(180, 150, 255, 0.35);
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(180, 150, 255, 0.2);
      }
      button:active {
        transform: translateY(1px);
      }
      button.active {
        background: rgba(180, 150, 255, 0.5);
        border-color: #d4bbff;
        box-shadow: 0 0 15px rgba(180, 150, 255, 0.6), inset 0 0 10px rgba(0, 0, 0, 0.3);
        text-shadow: 0 0 5px rgba(255, 255, 255, 0.8);
      }
      .dock-left button, .dock-right button {
        width: 100%; /* Uniform width inside vertical docks */
      }
      
      .divider {
        width: 2px;
        height: 24px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 2px;
      }
      .divider-h {
        height: 2px;
        width: 24px;
        background: rgba(255, 255, 255, 0.2);
        border-radius: 2px;
      }
    </style>
  </head>
  <body>
    <div class="app-layout">
      <!-- TOP DOCK -->
      <div class="dock dock-top">
        <div class="control-group">
          <label for="color-picker">Color</label>
          <input type="color" id="color-picker" value="#b496ff" />
        </div>
        <div class="divider"></div>
        <div class="control-group">
          <label for="size-picker">Size</label>
          <input type="range" id="size-picker" min="5" max="100" value="25" />
        </div>
        <div class="divider"></div>
        <div class="control-group">
          <label for="opacity-picker">Opacity</label>
          <input type="range" id="opacity-picker" min="5" max="100" value="100" />
        </div>
      </div>

      <!-- LEFT DOCK -->
      <div class="dock dock-left">
        <label>Tools</label>
        <button id="brush-toggle" class="tool-btn active">Brush</button>
        <button id="eraser-toggle" class="tool-btn">Eraser</button>
        <div class="divider-h"></div>
        <label>Shapes</label>
        <button id="square-toggle" class="tool-btn">Square</button>
        <button id="ellipse-toggle" class="tool-btn">Ellipse</button>
        <button id="triangle-toggle" class="tool-btn">Triangle</button>
      </div>

      <!-- CENTER WORKSPACE -->
      <div class="workspace">
        <MagicalCanvas />
      </div>

      <!-- RIGHT DOCK -->
      <div class="dock dock-right">
        <label>Effects</label>
        <button id="rainbow-toggle" class="toggle-btn">Rainbow</button>
        <button id="anim-toggle" class="toggle-btn active">Animate</button>
        <button id="fade-toggle" class="toggle-btn">Fade</button>
        <div class="divider-h"></div>
        <div class="control-group vert">
          <label for="fade-speed">Speed</label>
          <input type="range" id="fade-speed" min="1" max="60" value="5" />
        </div>
      </div>

      <!-- BOTTOM DOCK -->
      <div class="dock dock-bottom">
        <button id="clear-btn">Clear Canvas</button>
        <button id="import-btn">Import PNG</button>
        <button id="export-btn">Export PNG</button>
      </div>
    </div>

    <script>
      // Independent toggles
      document.querySelectorAll('.toggle-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          btn.classList.toggle('active');
        });
      });

      // Exclusive tool buttons
      const toolBtns = document.querySelectorAll('.tool-btn');
      toolBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          if (!btn.classList.contains('active')) {
            toolBtns.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
          }
        });
      });
    </script>
  </body>
</html>
