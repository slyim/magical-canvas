---
/* Component Script (Runs at build time) */
---

<div id="p5-container">
  <div id="cursor-ring">
    <svg width="100%" height="100%" viewBox="0 0 100 100" style="overflow:visible;">
      <circle id="cursor-circle" cx="50" cy="50" r="50" fill="none" stroke="rgba(180, 150, 255, 0.8)" stroke-width="1.5" vector-effect="non-scaling-stroke" style="display:none; filter: drop-shadow(0px 0px 2px rgba(180,150,255,0.6));" />
      <rect id="cursor-square" x="0" y="0" width="100" height="100" fill="none" stroke="rgba(180, 150, 255, 0.8)" stroke-width="1.5" vector-effect="non-scaling-stroke" style="display:none; filter: drop-shadow(0px 0px 2px rgba(180,150,255,0.6));" />
      <polygon id="cursor-triangle" points="50,0 6.7,75 93.3,75" fill="none" stroke="rgba(180, 150, 255, 0.8)" stroke-width="1.5" vector-effect="non-scaling-stroke" style="display:none; filter: drop-shadow(0px 0px 2px rgba(180,150,255,0.6));" />
    </svg>
  </div>
</div>

<style>
  #cursor-ring {
    position: fixed;
    pointer-events: none; /* Let clicks pass through! */
    transform: translate(-50%, -50%);
    z-index: 9999;
    display: none; /* Hidden when mouse is outside canvas */
  }

  #p5-container {
    aspect-ratio: 1 / 1;
    height: 100svh;
    max-height: calc(100svh - 220px);
    max-width: calc(100vw - 360px);
    width: auto;
    box-sizing: border-box;
    position: relative;
    border-radius: 20px;
    box-shadow: 0 0 40px rgba(180, 150, 255, 0.15), 0 0 100px rgba(0,0,0,0.8);
    border: 1px solid rgba(180, 150, 255, 0.2);
    overflow: hidden;
    background: #0d0617; /* Prevent flash of white before canvas loads */
    margin: 0;
    touch-action: none; /* Required for reliable pointer/touch tracking */
  }

  @media (max-width: 1000px) {
    #p5-container {
      width: calc(100vw - 40px);
      height: calc(100vw - 40px);
      max-width: none;
      max-height: none;
    }
  }

  :global(#p5-container canvas) {
    width: 100% !important;
    height: 100% !important;
    display: block !important;
    /* Strict square container means p5's bounding rect calculation is always correct */
  }

  /* The 3D WEBGL canvas is absolutely positioned and stacked on top of
     the 2D one. Only one is visible at a time — the mode toggle swaps them. */
  :global(#p5-container canvas.three-d-canvas) {
    position: absolute !important;
    inset: 0;
    z-index: 2;
  }
</style>

<script>
  import p5 from "p5";
  import { setupCanvas } from "../lib/canvas-engine.js";
  import { createHistory } from "../lib/history.js";
  import { getUIState, getActiveTool, getActive3DTool } from "../lib/ui-bridge.js";
  import { updateCursorRing } from "../lib/cursor.js";
  import { applyFadeEffect } from "../lib/effects.js";
  import { createParticleSystem } from "../lib/particle-system.js";
  import { createDrawingEngine } from "../lib/drawing-tools.js";
  import { exportPNG, setupImport } from "../lib/export.js";
  import { createScene3D } from "../lib/scene-3d.js";

  const initP5 = () => {
    // 3D scene — a second p5 instance in WEBGL mode. Set up before the 2D
    // sketch so its canvas can be stacked above/below the 2D one. The scene
    // starts hidden and pauses its own draw loop when not visible.
    const scene3D = createScene3D("p5-container", () => getUIState());

    // When the user switches modes, flip which canvas is visible.
    // The 2D canvas is hidden in 3D mode so the modes stay cleanly separated —
    // each keeps its own artwork intact when the user flips back.
    window.addEventListener("mode-change", (e: Event) => {
      const mode = (e as CustomEvent).detail?.mode;
      const twoD = document.querySelector<HTMLElement>("#p5-container canvas:not(.three-d-canvas)");
      if (mode === "3d") {
        scene3D.show();
        if (twoD) twoD.style.visibility = "hidden";
      } else {
        scene3D.hide();
        if (twoD) twoD.style.visibility = "visible";
      }
    });

    // Click-to-spawn for 3D tools. We listen on the 3D canvas only — so when
    // 2D is visible, nothing happens here. The orbitControl handles drag-
    // to-rotate, so a very short pointerdown→pointerup without movement is
    // treated as a "place" gesture.
    const spawnOnTap = () => {
      let down: { x: number; y: number; t: number } | null = null;
      const onDown = (e: PointerEvent) => {
        if (!scene3D.isVisible()) return;
        if ((e.target as Element | null)?.closest?.(".dock")) return;
        down = { x: e.clientX, y: e.clientY, t: performance.now() };
      };
      const onUp = (e: PointerEvent) => {
        if (!scene3D.isVisible() || !down) return;
        const dx = e.clientX - down.x;
        const dy = e.clientY - down.y;
        const dt = performance.now() - down.t;
        // Distinguish a tap from a camera drag
        if (Math.hypot(dx, dy) < 6 && dt < 400) {
          const ui = getUIState();
          const tool = getActive3DTool(ui);
          scene3D.spawn(tool, e.clientX, e.clientY);
        }
        down = null;
      };
      window.addEventListener("pointerdown", onDown);
      window.addEventListener("pointerup",   onUp);
    };
    spawnOnTap();

    const sketch = (p: p5) => {
      // ── Persistent drawing state ─────────────────────────────────────
      const history       = createHistory(p);
      const particles     = createParticleSystem(p);
      const drawingEngine = createDrawingEngine(p);

      // ── Input state ──────────────────────────────────────────────────
      let dragStartOnUI    = false;
      let isMouseOverCanvas = false;
      let currentPressure  = 1.0;
      let isDrawing        = false;

      // Unified input — populated by mouse (in draw) and touch hooks
      let inputActive = false;
      let inputX      = 0;
      let inputY      = 0;
      let prevInputX  = 0;
      let prevInputY  = 0;

      // ── Event listeners ──────────────────────────────────────────────

      // Pen pressure tracking
      window.addEventListener('pointermove', (e) => {
        currentPressure = e.pointerType === 'pen' && e.pressure > 0.05
          ? e.pressure : 1.0;
      });
      window.addEventListener('pointerdown', (e) => {
        currentPressure = e.pointerType === 'pen' && e.pressure > 0.05
          ? e.pressure : 1.0;
      });
      window.addEventListener('pointerup',     (e) => { if (e.pointerType === 'pen') currentPressure = 1.0; });
      window.addEventListener('pointercancel', (e) => { if (e.pointerType === 'pen') currentPressure = 1.0; });

      // UI drag lock — prevents accidental drawing when interacting with docks
      const setDragStartOnUI = (target: Element | null) => {
        dragStartOnUI = !!(target && target.closest('.dock'));
      };
      window.addEventListener('mousedown',  (e) => setDragStartOnUI(e.target as Element));
      window.addEventListener('touchstart', (e) => setDragStartOnUI(e.touches[0]?.target as Element), { passive: true });

      // Mouse hover tracking for cursor ring and draw guard
      const p5Container = document.getElementById('p5-container');
      if (p5Container) {
        p5Container.addEventListener('mouseenter', () => { isMouseOverCanvas = true; });
        p5Container.addEventListener('mouseleave', () => { isMouseOverCanvas = false; });
      }

      // Prevent spacebar from scrolling the page
      window.addEventListener('keydown', (e) => {
        if (e.code === 'Space') e.preventDefault();
      }, { passive: false });

      // ── p5 lifecycle ─────────────────────────────────────────────────

      p.setup = () => {
        setupCanvas(p);

        // Clear canvas — clears whichever mode is currently active
        document.getElementById('clear-btn')?.addEventListener('click', () => {
          if (scene3D.isVisible()) {
            scene3D.clear();
            return;
          }
          history.save();
          p.clear(0, 0, 0, 0);
          particles.clear();
          drawingEngine.resetStroke();
          const canvasEl = document.querySelector('#p5-container canvas:not(.three-d-canvas)') as HTMLElement;
          if (canvasEl) {
            canvasEl.style.transition = 'none';
            canvasEl.style.backgroundColor = 'rgba(255, 255, 255, 0.8)';
            setTimeout(() => {
              canvasEl.style.transition = 'background-color 0.4s ease-out';
              canvasEl.style.backgroundColor = 'transparent';
            }, 10);
          }
        });

        // Export PNG — picks the active canvas
        document.getElementById('export-btn')?.addEventListener('click', () => {
          if (scene3D.isVisible()) scene3D.exportPNG();
          else                     exportPNG();
        });

        // Import image
        const importInput = setupImport(p, (img: p5.Image) => {
          history.save();
          const ratio = Math.min(p.width / img.width, p.height / img.height);
          const newW  = img.width  * ratio;
          const newH  = img.height * ratio;
          p.image(img, p.width / 2 - newW / 2, p.height / 2 - newH / 2, newW, newH);
        });
        document.getElementById('import-btn')?.addEventListener('click', () => importInput.click());

        // Undo — reset engine so the in-progress stroke doesn't bridge across the jump
        document.getElementById('undo-btn')?.addEventListener('click', () => {
          if (history.undo()) drawingEngine.resetStroke();
        });

        // Redo
        document.getElementById('redo-btn')?.addEventListener('click', () => {
          if (history.redo()) drawingEngine.resetStroke();
        });
      };

      // ── Touch hooks — bridge touch into unified input state ──────────
      // p5 instance-mode lifecycle hooks aren't on the TS type; cast once.
      const pt = p as any;

      pt.touchStarted = () => {
        if (p.touches.length > 0) {
          const t = p.touches[0] as any;
          prevInputX = t.x;
          prevInputY = t.y;
          inputX     = t.x;
          inputY     = t.y;
          inputActive = true;
        }
        return false; // Prevents default scroll/zoom on iOS Safari
      };

      pt.touchMoved = () => {
        if (p.touches.length > 0) {
          const t = p.touches[0] as any;
          prevInputX = inputX;
          prevInputY = inputY;
          inputX = t.x;
          inputY = t.y;
        }
        return false; // Critical: prevents page scroll while drawing
      };

      pt.touchEnded = () => {
        if (p.touches.length === 0) inputActive = false;
        return false;
      };

      // Handle system interruptions (call, notification) so input isn't left stuck
      pt.touchCancelled = () => {
        inputActive = false;
        drawingEngine.resetStroke();
        return false;
      };

      // ── Draw loop ────────────────────────────────────────────────────

      p.draw = () => {
        const ui   = getUIState();
        const tool = getActiveTool(ui);

        // When 3D mode is active, the p5 WEBGL sketch is running on top.
        // Pause all 2D drawing work so the two engines don't fight over input.
        if (ui.is3D) {
          if (isDrawing) {
            isDrawing = false;
            drawingEngine.resetStroke();
          }
          return;
        }

        // Fade/trail effect
        if (ui.isFadeActive) applyFadeEffect(p, ui.fadeSpeed);

        // Cursor ring (desktop/stylus only — hidden on touch)
        updateCursorRing(p, isMouseOverCanvas, ui, tool);

        // Sync mouse into unified input (touch hooks update directly)
        if (p.touches.length === 0) {
          if (p.mouseIsPressed && isMouseOverCanvas) {
            inputActive = true;
            inputX      = p.mouseX;
            inputY      = p.mouseY;
            prevInputX  = p.pmouseX;
            prevInputY  = p.pmouseY;
          } else {
            inputActive = false;
          }
        }

        // Drawing gate: active input, not blocked by UI, not panning
        const canDraw = inputActive && !dragStartOnUI && !p.keyIsDown(32)
          && (p.touches.length > 0 || isMouseOverCanvas);

        if (canDraw) {
          if (!isDrawing) {
            isDrawing = true;
            history.save(); // Snapshot at the start of each stroke
          }
          drawingEngine.drawAtPoint({
            tool, inputX, inputY, prevInputX, prevInputY,
            currentPressure,
            color:     ui.color,
            size:      ui.size,
            opacity:   ui.opacity,
            isRainbow: ui.isRainbowActive,
            isAnim:    ui.isAnimActive,
          }, particles);
        } else {
          // Stroke ended — reset tracking
          if (isDrawing) {
            isDrawing = false;
            drawingEngine.resetStroke();
          }
        }

        // Advance and render all live particles
        particles.update();
      };

      p.windowResized = () => {
        // Canvas renders at fixed 1200×1200 — CSS scales it to fit.
        // No resize needed here.
      };
    };

    new p5(sketch);
  };

  if (typeof window !== 'undefined') {
    initP5();
  }
</script>
