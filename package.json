{
  "name": "nasty-neptune",
  "type": "module",
  "main": "main.js",
  "version": "0.0.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "desktop": "concurrently \"npm run dev\" \"wait-on tcp:4321 && electron .\"",
    "export:mac": "npm run build && electron-builder --mac",
    "export:win": "npm run build && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.nasty.neptune",
    "productName": "MagicalCanvas",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.png"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    }
  },
  "dependencies": {
    "astro": "^6.0.6",
    "electron-serve": "^3.0.1",
    "p5": "^2.2.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.4"
  }
}